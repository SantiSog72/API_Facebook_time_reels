// Contador global para la prueba
let contador = 0;

// Configuración del observador
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            contador++;
            // console.log("Nueva publicación vista. Total actual:", contador);
            // Dejamos de observar para no contar el mismo post dos veces
            observer.unobserve(entry.target);
        }
    });
}, { threshold: 0.5 });

// Función para buscar posts en el DOM
function observarPosts() {
    const posts = document.querySelectorAll('[role="article"]');
    posts.forEach(post => observer.observe(post));
    console.log("Observando", posts.length, "posts actuales.");
}

// Iniciar
observarPosts();

// Opcional: Si haces scroll y aparecen más, ejecuta esta función de nuevo
// o implementa un MutationObserver para hacerlo automático.