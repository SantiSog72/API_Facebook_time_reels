if (typeof raiz === 'undefined') {
	window.raiz = (window.BASE_URL || "/API_Facebook_time_reels/").replace(/\/$/, "") + "/";
}

let inicioAlerta;

function mostrarInterrupcion(contador, tiempo_total) {
    inicioAlerta = Date.now(); // Capturamos el momento exacto
    
    document.body.classList.add('bloqueado');
    const modal = document.createElement('div');
    modal.id = 'modal-interrupcion';
    modal.innerHTML = `
        <div style="background: white; padding: 30px; border-radius: 10px; text-align: center;">
            <h2>Tiempo de pausa</h2>
            <p>Publicaciones vistas: ${contador}</p>
            <p>Tiempo total: ${tiempo_total}</p>
            <button id="btn-continuar" style="padding: 10px 20px;">Continuar navegando</button>
        </div>
    `;
    document.body.appendChild(modal);

    document.getElementById('btn-continuar').onclick = function() {
        const tiempoReaccion = Date.now() - inicioAlerta; // Milisegundos que estuvo la alerta abierta
        
        // Enviar datos al servidor
        enviarDatosAlServidor(contador, tiempo_total, tiempoReaccion);
        
        document.body.classList.remove('bloqueado');
        modal.remove();
    };
}

function enviarDatosAlServidor(publi, tiempo, reaccion) {
    const url = 'http://localhost/API_Facebook_time_reels/guardar_datos.php';
    
    const datos = {
        publicaciones_vistas: publi,
        tiempo_sesion: tiempo,
        tiempo_reaccion_ms: reaccion,
        fecha: new Date().toISOString()
    };

    fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(datos)
    })
    .then(response => console.log('Datos enviados correctamente al servidor.'))
    .catch(error => console.error('Error al enviar:', error));
}