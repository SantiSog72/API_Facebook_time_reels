// seccion de identificar usuario

async function obtener_id_participante() {
	let userId = localStorage.getItem('participante_id');
    if (!userId) {
        userId = crypto.randomUUID();
        localStorage.setItem('participante_id', userId);
        
        let datos = new FormData();
        datos.append("participante_id", userId);

        try {
            const respuesta = await fetch('<?= WEB_ROOT ?>CONTROLADOR/crear_usuario.php', {
                method: 'POST',
                body: datos // Al enviar 'datos' (FormData), PHP llena $_POST automáticamente
            });
            const resultado = await respuesta.json();
            console.log("Registro en BD:", resultado);
        } catch (error) {
            console.error("Error al registrar:", error);
        }
    }
	return userId;
}

registrarSujeto();
console.log("ID del participante:", userId);