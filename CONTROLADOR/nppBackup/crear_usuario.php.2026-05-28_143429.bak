<?php
// Conexión a tu BD (db_usuarios o la que prefieras)
$conn = new mysqli("localhost", "root", "", "db_scroll_infinito");

$data = json_decode(file_get_contents('php://input'), true);
$id_participante = $data['participante_id'];

$sql = "INSERT INTO sujetos (id_sujeto) 
        VALUES ('$id_participante')";

if ($conn->query($sql)) {
    echo json_encode(['id_sesion' => $conn->insert_id]);
}
?>