<?php
$conn = new mysqli("localhost", "root", "", "bd_scroll_infinito");

// Al usar FormData en JS, los datos llegan por $_POST
if (isset($_POST['participante_id'])) {
    $id_participante = $_POST['participante_id'];

    // Usamos INSERT IGNORE por si el usuario recarga la página y el UUID ya existe
    $sql = "INSERT IGNORE INTO sujetos (id_sujeto) VALUES ('$id_participante')";

    if ($conn->query($sql)) {
        echo json_encode(['status' => 'success', 'id_recibido' => $id_participante]);
    } else {
        echo json_encode(['status' => 'error', 'msg' => $conn->error]);
    }
}
?>