<!DOCTYPE html>
<html>
<body>
<script>
    window.addEventListener("message", async (event) => {
        // IMPORTANTE: Cambia el origen si es necesario, 
        // pero Facebook siempre enviará desde 'https://www.facebook.com'
        if (event.origin !== "https://www.facebook.com") return;

        const datos = event.data;
        
        // El puente hace el fetch por ti, evitando el problema del CSP de Facebook
        try {
            const respuesta = await fetch('CONTROLADOR/crear_usuario.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            console.log("Datos del usuario enviados al PHP con éxito");
        } catch (error) {
            console.error("Error en el puente:", error);
        }
    });
</script>
</body>
</html>